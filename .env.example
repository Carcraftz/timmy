# Backend
DATABASE_URL=postgres://timmy:timmy@localhost:5432/timmy?sslmode=disable
TIMMY_TAILNET_NAME=your-tailnet-name
TIMMY_HOSTNAME=timmyd
TIMMY_STATE_DIR=./backend/.data/tsnet
TIMMY_LISTEN_ADDR=:443
TIMMY_USE_TLS=true

# Choose one auth path:
TS_AUTHKEY=
TS_CLIENT_SECRET=
TS_ADVERTISE_TAGS=

# CLI
TIMMY_API_URL=https://timmyd.your-tailnet.ts.net
# TIMMY_CONFIG=/absolute/path/to/config.json
